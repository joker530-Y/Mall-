# Copy to local environment variables or IDE run configuration.
# Do NOT commit real secrets.

# JWT
MALL_ADMIN_JWT_SECRET=mall-admin-dev-secret
MALL_PORTAL_JWT_SECRET=mall-portal-dev-secret

# Database
MALL_DB_URL=jdbc:mysql://localhost:3306/mall?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
MALL_DB_USERNAME=root
MALL_DB_PASSWORD=root

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/mall
RABBITMQ_USERNAME=mall
RABBITMQ_PASSWORD=mall

# MongoDB (optional)
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DATABASE=mall-port

# AI provider (optional)
AI_API_KEY=

# Alipay (disabled in mock-only mode)
ALIPAY_GATEWAY_URL=
ALIPAY_APP_ID=
ALIPAY_PUBLIC_KEY=
ALIPAY_PRIVATE_KEY=
ALIPAY_RETURN_URL=
ALIPAY_NOTIFY_URL=
